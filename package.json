{
  "name": "ferreteria-molina-manager",
  "version": "1.2.0",
  "description": "Sistema de Gestión Ferretería Molina",
  "main": "src/main/index.js",
  "scripts": {
    "start": "electron .",
    "dev": "nodemon --watch src --ext js,html,css --exec electron .",
    "rebuild": "electron-rebuild -f -w better-sqlite3",
    "pack": "electron-builder --dir",
    "dist": "electron-builder"
  },
  "build": {
    "appId": "com.ferreteriamolina.manager",
    "productName": "Ferretería Molina",
    "directories": {
      "output": "dist"
    },
    "files": [
      "src/**/*",
      "package.json",
      "node_modules/**/*"
    ],
    "win": {
      "target": "nsis",
      "icon": "build/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Ferretería Molina"
    },
    "linux": {
      "target": "AppImage",
      "category": "Office",
      "icon": "build/icon.png"
    },
    "mac": {
      "target": "dmg",
      "icon": "build/icon.icns"
    }
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "better-sqlite3": "^11.10.0",
    "electron-log": "^5.0.0",
    "fs-extra": "^11.3.5"
  },
  "devDependencies": {
    "electron": "^30.0.0",
    "electron-builder": "^24.13.3",
    "electron-rebuild": "^3.2.9",
    "nodemon": "^3.1.0"
  }
}
